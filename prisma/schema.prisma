generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  WRITER
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model User {
  id          Int        @id @default(autoincrement())
  username    String     @unique
  displayName String?
  password    String
  role        Role       @default(WRITER)
  createdAt   DateTime   @default(now())
  posts       Post[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  posts Post[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  postTags PostTag[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String
  content     String
  excerpt     String?
  thumbnail   String?
  language           String     @default("vi")
  translationGroupId Int?
  status             PostStatus @default(DRAFT)
  views       Int        @default(0)
  categoryId  Int?
  authorId    Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  category    Category?  @relation(fields: [categoryId], references: [id])
  author      User?      @relation(fields: [authorId], references: [id])
  images      PostImage[]
  postTags    PostTag[]

  @@unique([slug, language])
}

model PostImage {
  id     Int     @id @default(autoincrement())
  postId Int
  url    String
  alt    String?
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SitePage {
  id        Int      @id @default(autoincrement())
  key       String
  language  String
  content   String
  updatedAt DateTime @updatedAt

  @@unique([key, language])
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}
